# Note: AI configurations (Gemini/OpenAI API keys, Ollama endpoints) are configured
# directly in the web UI under Settings > LLM Server Library and saved in the database.
# There is no need to define GOOGLE_API_KEY or GEMINI_MODEL in this .env file.

# Security Configurations
JWT_SECRET_KEY=your_secure_random_jwt_secret_key_minimum_32_chars
ENCRYPTION_KEY=your_fernet_encryption_key_base64_format

# Database configuration (Optional: Defaults to SQLite pulse.db if omitted)
# DATABASE_URL=postgresql://user:password@localhost:5432/pulse_db

# Server Settings
PORT=8000
HOST=127.0.0.1

# Open-Source Instance Settings
# ALLOW_PUBLIC_REGISTRATION=True  # Se True, qualquer pessoa pode se cadastrar. Se False, novos registros públicos são bloqueados.
# REQUIRE_INVITE_CODE=False       # Se True, novos cadastros são obrigados a fornecer um código de convite.
ALLOW_PUBLIC_REGISTRATION=True
REQUIRE_INVITE_CODE=False

# X/Twitter OAuth 2.0 Client credentials (obtain from developer.x.com)
# App must be configured as 'Web App / Automated' with callback URL: http://localhost:8000/api/social/twitter/callback
# TWITTER_CLIENT_ID=your_twitter_client_id
# TWITTER_CLIENT_SECRET=your_twitter_client_secret


